{
  "_grid": {
    "name": "krea-2-turbo",
    "modelName": "Krea 2 Turbo",
    "engine": "comfyui",
    "jobType": "image",
    "deterministic": false,
    "requiredModels": ["Krea 2 Turbo"],
    "license": "Krea 2 is licensed under the Krea 2 Community License Agreement (krea.ai/krea-2-licensing) — commercial use permitted under $1M annual revenue.",
    "vars": {
      "prompt": "4.inputs.text",
      "seed": "7.inputs.seed",
      "steps": "7.inputs.steps",
      "width": "6.inputs.width",
      "height": "6.inputs.height",
      "sampler": "7.inputs.sampler_name",
      "scheduler": "7.inputs.scheduler"
    },
    "clamps": {
      "steps": [8, 12],
      "width": [512, 1536],
      "height": [512, 1536]
    },
    "enums": {
      "sampler": ["er_sde", "euler", "dpmpp_2m", "res_multistep"],
      "scheduler": ["simple", "normal", "beta", "sgm_uniform"]
    },
    "loraInject": {
      "model_src": ["1", 0],
      "clip_src": ["2", 0],
      "model_sinks": [["7", "model"]],
      "clip_sinks": [["4", "clip"]]
    }
  },
  "1": {
    "inputs": { "unet_name": "krea2_turbo_fp8.safetensors", "weight_dtype": "default" },
    "class_type": "UNETLoader",
    "_meta": { "title": "Load Krea2 Turbo" }
  },
  "2": {
    "inputs": { "clip_name": "qwen3vl_4b_fp8_scaled.safetensors", "type": "krea2", "device": "default" },
    "class_type": "CLIPLoader",
    "_meta": { "title": "Load Qwen3-VL (krea2)" }
  },
  "3": {
    "inputs": { "vae_name": "qwen_image_vae.safetensors" },
    "class_type": "VAELoader",
    "_meta": { "title": "Load VAE" }
  },
  "4": {
    "inputs": { "text": "", "clip": ["2", 0] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Prompt" }
  },
  "5": {
    "inputs": { "conditioning": ["4", 0] },
    "class_type": "ConditioningZeroOut",
    "_meta": { "title": "Negative (zeroed, cfg=1)" }
  },
  "6": {
    "inputs": { "width": 1280, "height": 720, "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" }
  },
  "7": {
    "inputs": {
      "seed": 0,
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "er_sde",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "inputs": { "samples": ["7", 0], "vae": ["3", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "inputs": { "filename_prefix": "krea2", "images": ["8", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
