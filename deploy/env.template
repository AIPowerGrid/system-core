# AI Power Grid — production environment template
# Copy to /etc/aipg/grid.env (chmod 600, owned by aipg) and fill in.
# bootstrap.sh generates the secrets automatically.

# ── Secrets (REQUIRED — the app refuses to boot without GRID_SALT) ──
# API-key salt. MUST be identical for system-core (Flask + grid_api) and the
# dashboard (grid-frontend GRID_SALT) or keys won't validate across systems.
# Generate: openssl rand -hex 32
GRID_SALT=__GENERATE_ME__

# ── Postgres ──
POSTGRES_USER=aipg
POSTGRES_PASS=__GENERATE_ME__
# host:port/dbname — Flask builds the URI from these parts
POSTGRES_URL=127.0.0.1:5432/aipg_grid

# Connection pool budget per Flask process:
# (DB_POOL_SIZE + DB_MAX_OVERFLOW) * 8 procs must stay under Postgres
# max_connections (bootstrap sets max_connections=300).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=15
DB_POOL_RECYCLE=1800

# ── Redis ──
# Flask uses DBs 0-5, grid_api uses DB 7 (streams/pubsub/quota/ratelimit).
REDIS_IP=127.0.0.1
REDIS_PORT=6379

# ── Free tier / economics ──
FREE_DAILY_LIMIT=200
PAID_KUDOS_THRESHOLD=1000

# ── Optional integrations (leave blank to disable) ──
# Stripe sponsor sync, Discord alerts, R2 image storage, IPFS pinning:
#STRIPE_API_KEY=
#DISCORD_WEBHOOK_URL=
#R2_ACCESS_KEY_ID=
#R2_SECRET_ACCESS_KEY=
#IPFS_PIN_URL=
#IPFS_API_KEY=
