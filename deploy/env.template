# AI Power Grid — production environment template
# Copy to /etc/aipg/grid.env (chmod 600, owned by aipg) and fill in.
# bootstrap.sh generates GRID_SALT + POSTGRES_PASS automatically.
#
# Sections marked [REQUIRED] must be set for that feature to work.
# Sections marked [OPTIONAL] degrade gracefully if unset.

# ════════════════════════════════════════════════════════════════════
# [REQUIRED] Core secrets — app refuses to boot without GRID_SALT
# ════════════════════════════════════════════════════════════════════
# API-key salt. MUST be identical for system-core (Flask + grid_api) AND the
# dashboard (grid-frontend GRID_SALT) or keys won't validate across systems.
# Generate: openssl rand -hex 32
GRID_SALT=__GENERATE_ME__

# ════════════════════════════════════════════════════════════════════
# [REQUIRED] Postgres
# ════════════════════════════════════════════════════════════════════
POSTGRES_USER=aipg
POSTGRES_PASS=__GENERATE_ME__
# host:port/dbname  (NOTE: no inline comments after values — systemd
# EnvironmentFile keeps them as part of the value, which breaks the DB name)
POSTGRES_URL=127.0.0.1:5432/aipg_grid

# Pool budget per Flask process:
# (DB_POOL_SIZE + DB_MAX_OVERFLOW) * 8 procs < postgres max_connections (300).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=15
DB_POOL_RECYCLE=1800

# ════════════════════════════════════════════════════════════════════
# [REQUIRED] Redis
# ════════════════════════════════════════════════════════════════════
# Flask uses DBs 0-5; grid_api uses DB 7 (streams/pubsub/quota/ratelimit).
REDIS_IP=127.0.0.1
REDIS_PORT=6379

# Base URL grid_api uses to reach the Flask pool for image/video jobs.
# Default localhost (co-located). Repoint when the API tier is split across VMs.
FLASK_API_BASE=http://127.0.0.1:7001

# ════════════════════════════════════════════════════════════════════
# [REQUIRED for image/video] R2 / S3 object storage
# ════════════════════════════════════════════════════════════════════
# WITHOUT THESE, generated images have nowhere to go — the code defaults to
# Haidra's "stable-horde" buckets, which this deployment cannot write to.
# Use Cloudflare R2 (S3-compatible) or any S3.
#
# *_ACCOUNT is the S3 endpoint URL (NOT just an account id). For R2 use the
# account/jurisdiction endpoint: https://<accountid>.r2.cloudflarestorage.com
R2_TRANSIENT_ACCOUNT=
R2_TRANSIENT_BUCKET=
R2_PERMANENT_ACCOUNT=
R2_PERMANENT_BUCKET=
R2_SOURCE_IMAGE_BUCKET=
# The horde also writes to a hardcoded "prompts" bucket — create it too.
#
# CREDENTIALS — set BOTH pairs to the same R2 key/secret:
#   - horde/r2.py builds its PRIMARY client from the default AWS cred chain,
#     so AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY MUST be set or uploads fail
#     silently (anonymous client).
#   - the secondary "shared" client reads SHARED_AWS_ACCESS_ID / _KEY.
# Use an R2 token with Object Read & Write on these buckets.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SHARED_AWS_ACCESS_ID=
SHARED_AWS_ACCESS_KEY=

# ════════════════════════════════════════════════════════════════════
# [OPTIONAL] Social login on the register page
# ════════════════════════════════════════════════════════════════════
# If unset, username-only registration still works; the OAuth buttons won't.
# Keep these consistent with the dashboard's OAuth config.
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
DISCORD_CLIENT_ID=

# ════════════════════════════════════════════════════════════════════
# [OPTIONAL] Anti-abuse on registration
# ════════════════════════════════════════════════════════════════════
# If unset, reCAPTCHA is skipped (registration still works, less bot-resistant).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ════════════════════════════════════════════════════════════════════
# [OPTIONAL] On-chain model registry (has working defaults)
# ════════════════════════════════════════════════════════════════════
# Defaults to the live Grid Diamond on Base + a public RPC. Override only to
# use your own RPC (recommended for reliability under load).
#GRID_DIAMOND_CONTRACT=0x79F39f2a0eA476f53994812e6a8f3C8CFe08c609
#GRID_DIAMOND_RPC_URL=https://base.publicnode.com

# ════════════════════════════════════════════════════════════════════
# [OPTIONAL] Free tier / economics (sane defaults shown)
# ════════════════════════════════════════════════════════════════════
FREE_DAILY_LIMIT=200
PAID_KUDOS_THRESHOLD=1000

# ════════════════════════════════════════════════════════════════════
# [OPTIONAL] Integrations
# ════════════════════════════════════════════════════════════════════
#STRIPE_API_KEY=                 # subscription -> monthly kudos sync
#DISCORD_WEBHOOK_URL=            # ops alerts (stuck jobs, low balance)
#IPFS_PIN_URL=                   # settlement audit pinning (Pinata etc.)
#IPFS_API_KEY=
#ADMINS=                         # comma-separated admin user IDs

# ════════════════════════════════════════════════════════════════════
# Site branding (optional; cosmetic)
# ════════════════════════════════════════════════════════════════════
HORDE_TITLE=AI Power Grid
HORDE_URL=https://aipowergrid.io
